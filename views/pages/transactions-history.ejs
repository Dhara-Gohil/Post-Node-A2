<link rel="stylesheet" href="/styles/app.css">

<h2>Transaction History</h2>

<div class="card" style="text-align:center;">
  <button type="button" onclick="location.href='/dashboard'">
    ← Back to Dashboard
  </button>
</div>

<div class="card">

  <form method="GET" action="/transactions" style="margin-bottom:10px; display:flex; gap:8px; flex-wrap:wrap;">

  <input type="text" name="search" placeholder="Search note..." value="<%= query.search || '' %>"/>

  <select name="type">
    <option value="">All Types</option>
    <option value="income" <%= query.type==='income'?'selected':'' %>>Income</option>
    <option value="expense" <%= query.type==='expense'?'selected':'' %>>Expense</option>
  </select>

  <button type="submit">Apply</button>

</form>

  <% if (transactions.length === 0) { %>
    <p>No transactions yet.</p>
  <% } else { %>
    <table>
      <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Amount</th>
        <th>Account</th>
        <th>Note</th>
        <th>Actions</th>
      </tr>

      <% transactions.forEach(function(tx){ %>

        <tr>
          <td><%= new Date(tx.createdAt).toLocaleDateString() %></td>
          <td><%= tx.type %></td>
          <td>₹<%= tx.amount %></td>
          <td><%= tx.account ? tx.account.name : '-' %></td>
          <td><%= tx.note || '-' %></td>
          <td>

            <button type="button" onclick="toggleEdit('<%= tx.id %>')">Edit</button>

            <form method="POST" action="/transactions/delete" style="display:inline;">
              <input type="hidden" name="id" value="<%= tx.id %>" />
              <button type="submit">Delete</button>
            </form>

          </td>
        </tr>

        <tr id="edit-<%= tx.id %>" style="display:none;">
          <td colspan="6">

            <form method="POST" action="/transactions/update" style="display:flex; gap:8px; flex-wrap:wrap;">

              <input type="hidden" name="id" value="<%= tx.id %>" />

              <input type="number" name="amount" value="<%= tx.amount %>" required />

              <select name="type">
                <option value="expense" <%= tx.type==='expense'?'selected':'' %>>Expense</option>
                <option value="income" <%= tx.type==='income'?'selected':'' %>>Income</option>
              </select>

              <button type="submit">Save</button>

            </form>

          </td>
        </tr>

      <% }) %>

    </table>

    <div style="margin-top:15px; text-align:center;">

  <% if (page > 1) { %>
    <a href="/transactions?page=<%= page-1 %>&search=<%= query.search || '' %>&type=<%= query.type || '' %>">
      <button>Previous</button>
    </a>
  <% } %>

  <span style="margin:0 10px;">
    Page <%= page %> of <%= totalPages %>
  </span>

  <% if (page < totalPages) { %>
    <a href="/transactions?page=<%= page+1 %>&search=<%= query.search || '' %>&type=<%= query.type || '' %>">
      <button>Next</button>
    </a>
  <% } %>

</div>

  <% } %>

</div>

<script>
function toggleEdit(id){
  const row = document.getElementById("edit-" + id);
  if(!row) return;
  row.style.display = row.style.display === "none" ? "table-row" : "none";
}
</script>

<script>
document.querySelectorAll('form[action="/transactions/delete"]').forEach(f=>{
  f.addEventListener('submit', async function(e){
    e.preventDefault();

    const res = await fetch('/transactions/delete',{
      method:'POST',
      body:new FormData(this)
    });

    const data = await res.json();

    if(data.success){
      location.reload();
    } else {
      alert(data.message);
    }
  });
});
</script>
